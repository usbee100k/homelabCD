#############################################
# Cluster Configuration
#############################################

CLUSTER_NAME="homelab"

LOCAL_IP="192.168.50.150" ## change if need

VIP_ADDRESS="192.168.50.222"

POD_SUBNET="10.10.0.0/16"

SERVICE_SUBNET="10.96.0.0/12"

DNS_DOMAIN="cluster.local"

BOOTSTRAP_REPO="git@github.com:usbee100k/homelab-deplyment.git"
# EXAMPLE : "git@github.com:youruser/bootstrap-config.git"


#############################################
# Features
#############################################

INSTALL_CILIUM=true

#############################################
# Cilium
#############################################

CILIUM_VERSION="1.18.1"


INSTALL_LONGHORN=true

INSTALL_INGRESS=true

INSTALL_ARGOCD=true

INSTALL_METRICS_SERVER=true

INSTALL_CERT_MANAGER=true


#####################################
# GITHUB
#####################################

GITHUB_REPO="https://github.com/usbee100k/homelabCD.git"

SSH_KEY_PATH="/etc/kubernetes/argocd/id_ed25519"

GIT_BRANCH="main"